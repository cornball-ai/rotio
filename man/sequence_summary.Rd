\name{sequence_summary}
\alias{sequence_summary}
\title{Concise human summary of a sequence}
\usage{
sequence_summary(seq)
}
\arguments{
\item{seq}{An \code{nle_sequence}.}
}
\description{
Prints a one-line per track + per clip overview. Useful for LLM agents
that need to "look at" a sequence without parsing the JSON.
}
